#!/usr/bin/env bash
# =============================================================================
# harnecess — Multi-Agent Orchestration Launcher
# =============================================================================
#
# Usage:
#   harnecess start [target-repo-path]   Launch all agents
#   harnecess stop                       Kill all sessions
#   harnecess status                     Show agent status
#   harnecess -h | --help                Show help
#
# Agents:
#   lead     — orchestrator (session: harnecess)
#   planner  — planning agent, Plan Mode (session: harnecess-agents, pane 0)
#   builder  — implementation agent (session: harnecess-agents, pane 1)
#   checker  — review/verification agent (session: harnecess-agents, pane 2)
#   writer   — documentation/output agent (session: harnecess-agents, pane 3)

set -e

# =============================================================================
# Resolve HARNECESS_ROOT via symlink resolution
# =============================================================================
_resolve_symlinks() {
    local path="$1"
    while [ -L "$path" ]; do
        local dir
        dir="$(cd -P "$(dirname "$path")" && pwd)"
        path="$(readlink "$path")"
        [[ "$path" != /* ]] && path="$dir/$path"
    done
    echo "$(cd -P "$(dirname "$path")" && pwd)"
}

HARNECESS_ROOT="$(_resolve_symlinks "${BASH_SOURCE[0]}")"

# Agent definitions
AGENTS=("lead" "planner" "builder" "checker" "writer")
AGENT_PANE_AGENTS=("planner" "builder" "checker" "writer")

SESSION_LEAD="harnecess"
SESSION_AGENTS="harnecess-agents"

# =============================================================================
# Color helpers
# =============================================================================
_c_reset="\033[0m"
_c_bold="\033[1m"
_c_red="\033[1;31m"
_c_green="\033[1;32m"
_c_yellow="\033[1;33m"
_c_blue="\033[1;34m"
_c_magenta="\033[1;35m"
_c_cyan="\033[1;36m"
_c_white="\033[1;37m"

log_info()    { echo -e "${_c_yellow}[info]${_c_reset} $1"; }
log_success() { echo -e "${_c_green}[done]${_c_reset} $1"; }
log_action()  { echo -e "${_c_cyan}[>>]${_c_reset} $1"; }
log_error()   { echo -e "${_c_red}[error]${_c_reset} $1"; }

# =============================================================================
# Generate UUID (portable: macOS + Linux)
# =============================================================================
generate_uuid() {
    if command -v uuidgen &>/dev/null; then
        uuidgen | tr '[:upper:]' '[:lower:]'
    elif [ -f /proc/sys/kernel/random/uuid ]; then
        cat /proc/sys/kernel/random/uuid
    else
        # Fallback: pseudo-UUID from /dev/urandom
        od -x /dev/urandom | head -1 | awk '{OFS="-"; print $2$3,$4,$5,$6,$7$8$9}'
    fi
}

